OAUTH_SERVER_URL=http://localhost:8080
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# ============================================
# AI/LLM Configuration - Groq (Free Tier Available)
# ============================================
# Get a free API key at: https://console.groq.com

# API Key - REQUIRED for AI features
GROQ_API_KEY=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

# Model Selection - Use SUPPORTED Groq models:
# - llama-3.1-8b-instant (RECOMMENDED - default, active and available)
# - mixtral-8x7b-32768 (Fallback option, also available)
# - llama-3.1-70b-versatile (DECOMMISSIONED - auto-fallback to llama-3.1-8b-instant)
# 
# See available models: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Cookie Configuration
# ============================================
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# ============================================
