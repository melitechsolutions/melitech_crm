# COMPREHENSIVE IMPLEMENTATION - ENVIRONMENT CONFIGURATION
# Copy this file as .env.local and fill in your values
# Never commit this file to version control!

# ============================================================================
# APPLICATION BASICS
# ============================================================================
NODE_ENV=development
DATABASE_URL=mysql://root:password@localhost:3306/melitech_crm
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# ============================================================================
# STRIPE PAYMENT GATEWAY
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET_HERE

# ============================================================================
# M-PESA PAYMENT GATEWAY (Africa's Talking / Daraja API)
# ============================================================================
# For sandbox: Create account at https://developer.safaricom.co.ke
# For production: Contact Safaricom for business integration
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a503b6e68bc3600b47dfe72425c20c2c40axxx

# Callback URL where M-Pesa will send transaction status
# This must be publicly accessible (ngrok for local development)
MPESA_CALLBACK_URL=https://yourapp.com/api/mpesa/callback

# ============================================================================
# EMAIL SERVICE (SMTP)
# ============================================================================
# Using Gmail: Enable "Less Secure App Access" or use App Password
# Using Custom Mailbox/SendGrid/etc: Use their SMTP credentials
EMAIL_FROM=noreply@melitechcrm.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_SECURE=false

# Mailhog (local development - email UI at http://localhost:8025)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=test
# SMTP_PASSWORD=test
# SMTP_SECURE=false

# ============================================================================
# SMS SERVICE (Africa's Talking)
# ============================================================================
# Get these from: https://africastalking.com/
SMS_PROVIDER=africa_talking
AFRICA_TALKING_API_KEY=your_api_key_from_africa_talking
AFRICA_TALKING_USERNAME=testapp
AFRICA_TALKING_SHORT_CODE=20880

# ============================================================================
# JOB SCHEDULER
# ============================================================================
# API key for triggering jobs externally (e.g., from external cron service)
CRON_API_KEY=your-secure-random-key-for-cron-triggers

# Timezone for scheduled jobs (e.g., 'Africa/Nairobi', 'UTC')
JOB_SCHEDULER_TIMEZONE=Africa/Nairobi

# ============================================================================
# VITE FRONTEND ENVIRONMENT
# ============================================================================
# These are available to frontend JavaScript
VITE_API_URL=/api/trpc
VITE_APP_TITLE=Melitech CRM
VITE_APP_VERSION=1.0.0

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Enable verbose logging
DEBUG=melitech:*

# Redis (optional, for caching/session)
# REDIS_URL=redis://localhost:6379

# AWS S3 (for file storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# ============================================================================
# DOCKER COMPOSE OVERRIDES
# ============================================================================
# Database
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=melitech_crm
MYSQL_USER=melitech_user
MYSQL_PASSWORD=melitech_password

# Mailhog (Development only)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRY_DAYS=90

# Session timeout (minutes)
SESSION_TIMEOUT=30

# Brute force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ============================================================================
# WEBHOOK SECRETS
# ============================================================================
# For validating incoming webhooks from payment providers
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
MPESA_WEBHOOK_SECRET=your_webhook_verification_token
SMSSERVICE_WEBHOOK_SECRET=your_webhook_verification_token

# ============================================================================
# REPORTING & LOGGING
# ============================================================================
# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Store logs in file (optional)
LOG_FILE_PATH=./logs/app.log

# Sentry error tracking (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_STRIPE_PAYMENTS=true
FEATURE_MPESA_PAYMENTS=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=true
FEATURE_SCHEDULER_MONITORING=true

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================
# Automatic daily backup time (24-hour format, UTC)
BACKUP_TIME=02:00

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Google Analytics (optional)
# VITE_GA_ID=UA-XXXXXXXXX-X

# Intercom / Customer Support (optional)
# INTERCOM_APP_ID=your_intercom_app_id

# Drift / Live Chat (optional)
# DRIFT_ACCOUNT_ID=your_drift_account_id
