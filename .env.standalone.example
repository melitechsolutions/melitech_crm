# Melitech CRM - Standalone Deployment Environment Configuration
# Copy this file to .env and fill in the required values

# ============= DATABASE =============
# MySQL/TiDB connection string for local authentication and data storage
DATABASE_URL="mysql://user:password@localhost:3306/melitech_crm"

# ============= AUTHENTICATION =============
# JWT secret for signing session tokens (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ============= APPLICATION SETTINGS =============
# Application title displayed in UI
VITE_APP_TITLE="Melitech Solutions CRM"

# Application logo URL (can be local or remote)
VITE_APP_LOGO="https://your-domain.com/logo.png"

# Frontend application ID (for local auth, can be any string)
VITE_APP_ID="melitech-crm-standalone"

# ============= OPTIONAL: MANUS OAUTH (Disable for Standalone) =============
# Leave these empty or commented out for standalone deployment
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ============= OPTIONAL: OWNER NOTIFICATIONS =============
# For owner notification features (optional)
OWNER_NAME="Admin"
OWNER_OPEN_ID="admin-user-id"

# ============= OPTIONAL: ANALYTICS =============
# For analytics tracking (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============= SERVER CONFIGURATION =============
# Port for the Express server
PORT=3000

# Node environment
NODE_ENV="production"

# ============= DEPLOYMENT NOTES =============
# For production deployment:
# 1. Generate a strong JWT_SECRET: openssl rand -base64 32
# 2. Use a secure database connection string with proper credentials
# 3. Set NODE_ENV to "production"
# 4. Use HTTPS for all connections
# 5. Keep .env file secure and never commit to version control
# 6. Update VITE_APP_LOGO with your company logo
# 7. Update VITE_APP_TITLE with your application name
