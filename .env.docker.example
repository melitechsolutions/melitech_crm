# Docker Environment Configuration for Melitech CRM
# Copy this file to .env.docker and update values for your deployment

# ============================================
# Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=melitech_crm
MYSQL_USER=melitech
MYSQL_PASSWORD=melitech_password

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
DATABASE_URL=mysql://melitech:melitech_password@mysql:3306/melitech_crm

# ============================================
# Authentication & OAuth
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# ============================================
# Owner/Admin Configuration
# ============================================
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Admin User

# ============================================
# Application Branding
# ============================================
VITE_APP_TITLE=Melitech Solutions CRM
VITE_APP_LOGO=https://your-domain.com/logo.png

# ============================================
# Manus Built-in APIs
# ============================================
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ============================================
# Analytics
# ============================================
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================
# Port Configuration
# ============================================
PORT=3000
MYSQL_PORT=3306
REDIS_PORT=6379

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_DIR=/app/logs
